# EditorConfig https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
max_line_length = 100
trim_trailing_whitespace = true

[*.{css}]
max_line_length = 160

[*.{md,mdx}]
trim_trailing_whitespace = false
